<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CPK_Calculate.CPKResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CPK_Calculate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CPK Calculation System">

    <Grid x:Name="ResultRoot" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TitleBar x:Name="ResultTitleBar"
                  Grid.Row="0"
                  Title="CPK Analysis Result"
                  IsBackButtonVisible="False"
                  IsPaneToggleButtonVisible="False"
                  Padding="16,10"
                  Height="48">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Square44x44Logo.png"/>
            </TitleBar.IconSource>
            <TitleBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="CPK Calculation System" FontWeight="SemiBold"/>
                </StackPanel>
            </TitleBar.Content>
        </TitleBar>

        <!-- Main split: charts (left) | history panel (right) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT: Charts ===== -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel Spacing="16">

                    <!-- CPK Statistics Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20,16">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                            <Grid Grid.Row="0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="CPK STATISTICS" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Padding="12,4">
                                    <TextBlock x:Name="StatDateBadge" Text="" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource CpkOverallBrush}"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="*,2*,*" ColumnSpacing="20">
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Text="WITHIN" FontWeight="Bold" FontSize="13" Foreground="#1ABC9C"/>
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5" ColumnSpacing="10">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="StDev" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="WithinStDev" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Cp" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="WithinCp" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cpk" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="WithinCpk" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="PPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="WithinPPM" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="WITHIN (CPK)" FontWeight="SemiBold" FontSize="12" Foreground="#1ABC9C"/>
                                        <Grid Height="10" CornerRadius="5">
                                            <Border Background="#E0F7F1" CornerRadius="5"/>
                                            <Border x:Name="CpkBar" Background="#1ABC9C" CornerRadius="5" HorizontalAlignment="Left" Width="0"/>
                                        </Grid>
                                        <TextBlock x:Name="CpkBarValue" Text="" HorizontalAlignment="Right" FontWeight="Bold" FontSize="13" Foreground="#1ABC9C"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="OVERALL (PPK)" FontWeight="SemiBold" FontSize="12" Foreground="#E67E22"/>
                                        <Grid Height="10" CornerRadius="5">
                                            <Border Background="#FDEBD0" CornerRadius="5"/>
                                            <Border x:Name="PpkBar" Background="#E67E22" CornerRadius="5" HorizontalAlignment="Left" Width="0"/>
                                        </Grid>
                                        <TextBlock x:Name="PpkBarValue" Text="" HorizontalAlignment="Right" FontWeight="Bold" FontSize="13" Foreground="#E67E22"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="8">
                                    <TextBlock Text="OVERALL" FontWeight="Bold" FontSize="13" Foreground="#E67E22" HorizontalAlignment="Right"/>
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="5" ColumnSpacing="10">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="StDev" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OverallStDev" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Pp" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="OverallPp" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ppk" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="OverallPpk" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Cpm" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="OverallCpm" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="PPM" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="OverallPPM" Text="-" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="24">
                                <TextBlock x:Name="SpecInfo" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CPK Histogram Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="CPK HISTOGRAM" FontWeight="Bold" FontSize="14"/>
                                <StackPanel Orientation="Horizontal" Spacing="14" Margin="20,0,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="10" Height="10" Fill="{ThemeResource CpkWithinBrush}"/>
                                        <TextBlock Text="Data" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="10" Height="10" Fill="{ThemeResource CpkOverallBrush}"/>
                                        <TextBlock Text="Overall" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="10" Height="10" Fill="{ThemeResource CpkWithinCurveBrush}"/>
                                        <TextBlock Text="Within" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <Canvas x:Name="HistogramCanvas" Height="240" HorizontalAlignment="Stretch"
                                    SizeChanged="HistogramCanvas_SizeChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- X-bar Chart Card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock Text="XBAR CHART" FontWeight="Bold" FontSize="14"/>
                                <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Right">
                                    <TextBlock x:Name="XbarUCL" FontSize="12" FontWeight="Bold" Foreground="#E74C3C"/>
                                    <TextBlock x:Name="XbarCL" FontSize="12" FontWeight="Bold" Foreground="#1ABC9C"/>
                                    <TextBlock x:Name="XbarLCL" FontSize="12" FontWeight="Bold" Foreground="#E74C3C"/>
                                </StackPanel>
                            </Grid>
                            <Canvas x:Name="XbarCanvas" Height="220" HorizontalAlignment="Stretch"
                                    SizeChanged="XbarCanvas_SizeChanged"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Vertical Divider -->
            <Border Grid.Column="1" Width="1"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                    VerticalAlignment="Stretch"/>

            <!-- ===== RIGHT: Data Table ===== -->
            <Grid Grid.Column="2">
                <Border Margin="0,20,20,20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section header -->
                    <Border Grid.Row="0" Padding="12,10"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A9;" FontSize="13" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="DATA TABLE" FontWeight="Bold" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       x:Name="DataTableInfoTxt"
                                       Text=""
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"/>
                        </Grid>
                    </Border>

                    <!-- Column headers -->
                    <Grid Grid.Row="1" Padding="8,6"
                          Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="86"/>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="56"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"               FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Ratio"           FontWeight="SemiBold" FontSize="11" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="Prod. Date"      FontWeight="SemiBold" FontSize="11" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="Lot No."         FontWeight="SemiBold" FontSize="11" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="4" Text="Sample"          FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="Value (Po)"      FontWeight="SemiBold" FontSize="11" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="6" Text="Status"          FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Data rows -->
                    <ListView x:Name="DataTableListView" Grid.Row="2"
                              SelectionMode="None"
                              HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="34"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:PoDataRow">
                                <Grid Padding="8,5"
                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                      BorderThickness="0,0,0,0.5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="86"/>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind No}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Ratio}"
                                               VerticalAlignment="Center" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind ProductionDate}"
                                               VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind LotNo}"
                                               VerticalAlignment="Center" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="4" Text="{x:Bind SampleNo}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                                    <TextBlock Grid.Column="5" Text="{x:Bind Value}"
                                               VerticalAlignment="Center" FontSize="12"
                                               FontWeight="SemiBold" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="6" Text="{x:Bind Status}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{x:Bind StatusBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                     </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                    </Border>
                                </Grid>

        </Grid>
    </Grid>
</Window>
