<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPK_Calculate.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CPK_Calculate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="24,20,24,12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE81C;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <TextBlock Text="Analysis History" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock x:Name="RecordCountTxt" Text="0 records" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Click="Refresh_Click" ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" Padding="24,0,24,24">

            <!-- Loading -->
            <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="40" Height="40"/>
                <TextBlock Text="Loading data from server..." HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Error -->
            <Border x:Name="ErrorPanel" Visibility="Collapsed"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                    CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xEA39;" FontSize="32" HorizontalAlignment="Center"
                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    <TextBlock x:Name="ErrorMessage" Text="Unable to connect to server."
                               HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    <Button Content="Retry" HorizontalAlignment="Center" Click="Refresh_Click"
                            Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyPanel" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE7BC;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                <TextBlock Text="No analysis records found." HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14"/>
            </StackPanel>

            <!-- Data Table -->
            <Border x:Name="DataPanel" Visibility="Collapsed"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column Headers -->
                    <Grid Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                          Padding="16,10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Title" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Date" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Time" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Action" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Data Rows -->
                    <ListView x:Name="HistoryListView" Grid.Row="1"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="HistoryListView_ItemClick"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="44"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:HistoryRowItem">
                                <Grid Padding="16,8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,0.5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind RowNumber}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Id}" FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{x:Bind DateText}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind TimeText}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <Button Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center"
                                            ToolTipService.ToolTip="Delete" Click="Delete_Click" Tag="{x:Bind Id}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Loading overlay for detail fetch -->
                    <Grid x:Name="DetailLoadingOverlay" Grid.RowSpan="2" Visibility="Collapsed"
                          Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                            <ProgressRing IsActive="True" Width="36" Height="36"/>
                            <TextBlock Text="Loading analysis data..." HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
