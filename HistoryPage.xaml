<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPK_Calculate.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CPK_Calculate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="24,24,24,12">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE81C;" FontSize="22" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                <StackPanel Spacing="2">
                    <TextBlock Text="Analysis History" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" FontSize="20"/>
                    <TextBlock Text="Review and manage your saved CPK analysis records." 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Padding="12,6" CornerRadius="4" Background="{ThemeResource AccentFillColorSecondaryBrush}">
                    <TextBlock x:Name="RecordCountTxt" Text="0 records" FontWeight="Medium" FontSize="12"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                </Border>
                <Button Click="Refresh_Click" Style="{StaticResource AccentButtonStyle}" Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="Refresh Data"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="0,0,0,1">
                <Grid Padding="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="Analysis Title" FontWeight="Bold" Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="Date" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Time" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Action" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <ListView x:Name="HistoryListView" Grid.Row="1"
                      SelectionMode="None" IsItemClickEnabled="True"
                      ItemClick="HistoryListView_ItemClick" Padding="0" Background="Transparent">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="MinHeight" Value="52"/>
                        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:HistoryRowItem">
                        <Grid Padding="16,10" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind RowNumber}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorDisabledBrush}"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Id}" FontSize="10" Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{x:Bind DateText}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind TimeText}" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Button Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Click="Delete_Click" Tag="{x:Bind Id}" Style="{StaticResource SubtleButtonStyle}">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid x:Name="LoadingPanel" Grid.RowSpan="2" Visibility="Collapsed" Background="Transparent">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressRing IsActive="True" Width="32" Height="32"/>
                    <TextBlock Text="Fetching records..." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="EmptyPanel" Grid.RowSpan="2" Visibility="Collapsed" Background="Transparent">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE7BC;" FontSize="48" Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                    <TextBlock Text="No records found." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="DetailLoadingOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="36" Height="36"/>
                <TextBlock Text="Loading analysis data..." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>