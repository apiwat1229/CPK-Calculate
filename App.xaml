<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CPK_Calculate.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CPK_Calculate">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- App-wide resources -->
            <x:String x:Key="AppTitle">CPK Calculation System</x:String>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <x:String x:Key="AppTitle">CPK Calculation System</x:String>
                    <SolidColorBrush x:Key="CpkWithinBrush" Color="#FF1ABC9C"/>
                    <SolidColorBrush x:Key="CpkOverallBrush" Color="#FFE67E22"/>
                    <SolidColorBrush x:Key="CpkWithinCurveBrush" Color="#FF2C3E50"/>
                    <SolidColorBrush x:Key="CpkGridLineBrush" Color="#20808080"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <x:String x:Key="AppTitle">CPK Calculation System</x:String>
                    <SolidColorBrush x:Key="CpkWithinBrush" Color="#FF1ABC9C"/>
                    <SolidColorBrush x:Key="CpkOverallBrush" Color="#FFE67E22"/>
                    <SolidColorBrush x:Key="CpkWithinCurveBrush" Color="#FFB0C4C8"/>
                    <SolidColorBrush x:Key="CpkGridLineBrush" Color="#20808080"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <x:String x:Key="AppTitle">CPK Calculation System</x:String>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
