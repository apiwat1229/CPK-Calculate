<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPK_Calculate.CPKPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CPK_Calculate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xEC42;" FontSize="24" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <TextBlock Text="Capability Analysis (CPK)" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold"/>
            </StackPanel>

            <Grid ColumnDefinitions="1*, 2*" ColumnSpacing="24">
                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <Grid>
                            <TextBlock Text="Control Parameters" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2">
                                    <TextBlock x:Name="DataCountTxt" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Items" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <TextBox x:Name="DataInputBox" Height="250" AcceptsReturn="True" 
                                 PlaceholderText="Paste numbers here..." TextChanged="DataInputBox_TextChanged"
                                 FontSize="13" FontFamily="Consolas"/>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <NumberBox x:Name="LSLInput" Header="LSL" Value="38" SpinButtonPlacementMode="Compact"/>
                            <NumberBox x:Name="USLInput" Header="USL" Value="48" Grid.Column="1" SpinButtonPlacementMode="Compact"/>
                            <NumberBox x:Name="SizeInput" Header="Size" Value="18" Grid.Column="2" SpinButtonPlacementMode="Compact"/>
                        </Grid>

                        <Button Content="Calculate Analysis" Style="{ThemeResource AccentButtonStyle}" 
                                HorizontalAlignment="Stretch" Height="40" Click="Calculate_Click"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" 
                            BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid ColumnDefinitions="140, *, 140" ColumnSpacing="20">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="WITHIN" FontWeight="Black" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="StDev" FontSize="12"/>
                                    <TextBlock x:Name="StDevWTxt" Grid.Column="1" FontWeight="Bold" Text="0.000"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="Cp" FontSize="12"/>
                                    <TextBlock x:Name="CpTxt" Grid.Column="1" FontWeight="Bold" Foreground="Teal" Text="0.00"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="Cpk" FontSize="12"/>
                                    <TextBlock x:Name="CpkTxt" Grid.Column="1" FontWeight="Bold" Foreground="Teal" Text="0.00"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="PPM" FontSize="12"/>
                                    <TextBlock x:Name="PpmWTxt" Grid.Column="1" FontWeight="Bold" Text="0.00"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="20">
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <TextBlock Text="WITHIN (CPK)" FontSize="10" FontWeight="Bold" Foreground="Teal"/>
                                        <TextBlock x:Name="BarCpkVal" HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Text="0.00"/>
                                    </Grid>
                                    <ProgressBar x:Name="BarCpk" Value="0" Maximum="2" Foreground="Teal" Height="4"/>
                                    <Border x:Name="CpkStatusBorder" HorizontalAlignment="Center" Padding="8,2" CornerRadius="4">
                                        <TextBlock x:Name="CpkStatusTxt" Text="-" FontSize="10" FontWeight="Black"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <TextBlock Text="OVERALL (PPK)" FontSize="10" FontWeight="Bold" Foreground="OrangeRed"/>
                                        <TextBlock x:Name="BarPpkVal" HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Text="0.00"/>
                                    </Grid>
                                    <ProgressBar x:Name="BarPpk" Value="0" Maximum="2" Foreground="OrangeRed" Height="4"/>
                                    <Border x:Name="PpkStatusBorder" HorizontalAlignment="Center" Padding="8,2" CornerRadius="4">
                                        <TextBlock x:Name="PpkStatusTxt" Text="-" FontSize="10" FontWeight="Black"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="OVERALL" FontWeight="Black" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="StDev" FontSize="12"/>
                                    <TextBlock x:Name="StDevOTxt" Grid.Column="1" FontWeight="Bold" Text="0.000"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="Pp" FontSize="12"/>
                                    <TextBlock x:Name="PpTxt" Grid.Column="1" FontWeight="Bold" Foreground="OrangeRed" Text="0.00"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="Ppk" FontSize="12"/>
                                    <TextBlock x:Name="PpkTxt" Grid.Column="1" FontWeight="Bold" Foreground="OrangeRed" Text="0.00"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="Cpm" FontSize="12"/>
                                    <TextBlock x:Name="CpmTxt" Grid.Column="1" FontWeight="Bold" Foreground="OrangeRed" Text="0.00"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Text="PPM" FontSize="12"/>
                                    <TextBlock x:Name="PpmOTxt" Grid.Column="1" FontWeight="Bold" Text="0.00"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" MinHeight="200" 
                            BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <TextBlock x:Name="SummaryTxt" Text="Mean: 0.00" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>