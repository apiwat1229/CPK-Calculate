<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CPK_Calculate.ExcelDataEntryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CPK_Calculate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Padding="24,16,24,12" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE9F9;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="PageTitle" Text="Data Entry Sheet" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                <local:InfoLabel x:Name="InfoDateTxt" Icon="&#xE787;" Label="Date:"/>
                <local:InfoLabel x:Name="InfoGradeTxt" Icon="&#xE8EC;" Label="Grade:"/>
            </StackPanel>
        </StackPanel>

        <!-- Row Creator -->
        <Border Grid.Row="1" Margin="24,0,24,0" Padding="12" CornerRadius="6"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="4">
                <!-- Row 0: Labels -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ratio (CL / USS / BK)" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Lot Number" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Sample No." FontWeight="SemiBold" FontSize="12"/>

                <!-- Row 1: Inputs aligned -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <NumberBox x:Name="RatioCL" Value="0" Minimum="0" Maximum="100" Width="90"
                               SpinButtonPlacementMode="Hidden" HorizontalContentAlignment="Center"
                               ValueChanged="Ratio_ValueChanged"/>
                    <TextBlock Text="/" VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <NumberBox x:Name="RatioUSS" Value="0" Minimum="0" Maximum="100" Width="90"
                               SpinButtonPlacementMode="Hidden" HorizontalContentAlignment="Center"
                               ValueChanged="Ratio_ValueChanged"/>
                    <TextBlock Text="/" VerticalAlignment="Center" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <NumberBox x:Name="RatioBK" Value="0" Minimum="0" Maximum="100" Width="90"
                               SpinButtonPlacementMode="Hidden" HorizontalContentAlignment="Center"
                               ValueChanged="Ratio_ValueChanged"/>
                </StackPanel>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="LotNumberInput" PlaceholderText="Enter lot number..."
                         Width="160" VerticalAlignment="Center" BeforeTextChanging="LotNumberInput_BeforeTextChanging" InputScope="Number"/>
                <NumberBox Grid.Row="1" Grid.Column="2" x:Name="SampleCountInput" Value="18" Minimum="1" Maximum="100"
                           Width="120" SpinButtonPlacementMode="Inline" VerticalAlignment="Center"/>
                <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Center" Padding="16,8" Click="AddRows_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                        <TextBlock Text="Add Rows"/>
                    </StackPanel>
                </Button>

                <!-- Row 2: Total -->
                <TextBlock Grid.Row="2" Grid.Column="0" x:Name="RatioSumTxt" Text="Total: 0 / 100" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>
        </Border>

        <!-- Data Table -->
        <Grid Grid.Row="2" Padding="24,12,24,24">
            <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column Headers -->
                    <Grid Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                          Padding="0,10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ratio" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Production Date" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Lot No." FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Sample No." FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="PO Value" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    </Grid>

                    <!-- Data Rows -->
                    <ListView x:Name="MeasurementGrid" Grid.Row="1"
                              SelectionMode="Single"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="36"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:MeasurementRow">
                                <Grid Padding="0,4" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,0.5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Ratio}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind ProdDate}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind LotNo}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind SampleNo}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBox Grid.Column="4"
                                             Text="{x:Bind ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             TextAlignment="Center"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                             FontWeight="Bold"
                                             PlaceholderText="-"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Padding="24,12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    <TextBlock x:Name="DataCountTxt" Text="Count: 0" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SummaryTxt" Text="Mean: 0.00" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Content="Reset Data" Click="Reset_Click" Width="120"/>
                    <Button Content="Calculate CPK" Style="{StaticResource AccentButtonStyle}" Click="Calculate_Click" Width="160"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>